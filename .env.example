# ===========================================
# Smithery Claude Proxy 配置文件
# ===========================================

# 域名配置
DOMAIN=api.inter-trade.top

# Smithery.ai配置
SMITHERY_URL=https://smithery.ai
SMITHERY_AUTH_TOKEN=base64-YOUR_SMITHERY_AUTH_TOKEN_HERE
SMITHERY_WOS_SESSION=Fe26.2*YOUR_WOS_SESSION_HERE

# 服务配置
HOST=0.0.0.0
PORT=20179
DEBUG=false
WORKERS=4

# 数据库配置
DATABASE_URL=sqlite:///./users.db

# JWT认证配置
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30天

# 用户系统配置
ALLOW_REGISTRATION=true
DEFAULT_USER_ACTIVE=true

# API配置
API_RATE_LIMIT=100  # 每分钟请求限制
MAX_TOKENS_PER_REQUEST=4000

# MCP配置
MCP_TIMEOUT=30
MCP_RETRY_ATTEMPTS=3

# MCP Playground 配置
ENABLE_MCP_TOOLS=true
MCP_CACHE_TTL=3600
MCP_MAX_CONCURRENT_CALLS=5
MCP_TOOL_TIMEOUT=30
MCP_SEARCH_PAGE_SIZE=20

# 工具配置
TOOLS_ENABLED=true
GOOGLE_SEARCH_API_KEY=YOUR_GOOGLE_SEARCH_API_KEY
GOOGLE_SEARCH_CX=YOUR_GOOGLE_SEARCH_CX
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_TIMEOUT=30
WEB_FETCH_TIMEOUT=10
MAX_SEARCH_RESULTS=5
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_BASE_URL=https://your-gemini-proxy.example.com

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS配置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# 可选：代理配置
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# 可选：邮件配置（用于通知）
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com

# 可选：监控配置
# SENTRY_DSN=https://your-sentry-dsn
# PROMETHEUS_ENABLED=false
